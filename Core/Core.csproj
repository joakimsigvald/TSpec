<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>A fluent Given-When-Then specification framework for xUnit. Write behavior definitions as unit tests with built-in auto-mocking and data generation</Description>
		<VersionPrefix></VersionPrefix>
		<Authors>Joakim Sigvald</Authors>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		<LangVersion>latest</LangVersion>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
		<AssemblyName>TSpec</AssemblyName>
		<RootNamespace>TSpec</RootNamespace>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<IsPackable>true</IsPackable>
		<PackageTags>unit test specification given when then fluent mock xunit moq automock</PackageTags>
		<PackageProjectUrl>https://github.com/joakimsigvald/TSpec</PackageProjectUrl>
		<RepositoryUrl>https://github.com/joakimsigvald/TSpec.git</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageVersion>1.2.1</PackageVersion>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageIcon>icon.png</PackageIcon>
		<PackageReleaseNotes>
			Bug-fix release:
			- Async test methods fully supported (the specification context now follows the test's async flow)
			- TSpec.Assert works standalone, without a Spec base class
			- Deferred sequences are lazily cached during assertion: each element produced at most once, infinite sequences supported
			- Readable failure descriptions: actual count stated, at most five elements shown, elements rendered by ToString capped at 50 characters
			- Throws() and DoesNotThrow are included in the generated specification; clearer failure when Throws(expected) receives a look-alike exception instance
			- SetupFailed instead of NotImplementedException for unsupported mock setups
		</PackageReleaseNotes>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Moq" Version="4.20.72" />
		<PackageReference Include="xunit.v3.extensibility.core" Version="3.2.2" />
		<PackageReference Include="xunit.v3.assert" Version="3.2.2" />
		<None Include="..\README.md" Pack="true" PackagePath="\" />
		<None Include="..\TSpec-agent-reference.md" Pack="true" PackagePath="\" />
		<None Include="..\icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
